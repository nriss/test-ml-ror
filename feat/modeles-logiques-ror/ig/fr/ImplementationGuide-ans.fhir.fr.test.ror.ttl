       fhir:name [ fhir:v "ROR - Organisation Interne" ] ;
       fhir:description [ fhir:v "Modèle logique ROR représentant une organisation interne d'une structure de santé (pôle, service, unité fonctionnelle). Cette entité n'existe pas dans le MOS et est propre au ROR." ] ;
