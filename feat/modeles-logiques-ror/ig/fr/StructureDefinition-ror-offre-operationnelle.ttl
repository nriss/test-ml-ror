       fhir:id [ fhir:v "ror-offre-operationnelle.specialisationPriseEnCharge" ] ;
       fhir:path [ fhir:v "ror-offre-operationnelle.specialisationPriseEnCharge" ] ;
       fhir:short [ fhir:v "Une spécialisation de prise en charge correspond à un regroupement de troubles, de pathologies ou de déficiences qui nécessitent la mobilisation d'expertises, de compétences et/ou d'équipements spécifiques pouvant être discriminants dans le choix d’orientation du patient." ] ;
       fhir:definition [ fhir:v "Une spécialisation de prise en charge correspond à un regroupement de troubles, de pathologies ou de déficiences qui nécessitent la mobilisation d'expertises, de compétences et/ou d'équipements spécifiques pouvant être discriminants dans le choix d’orientation du patient." ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
