       fhir:id [ fhir:v "ror-offre-operationnelle.uniteSensible" ] ;
       fhir:path [ fhir:v "ror-offre-operationnelle.uniteSensible" ] ;
       fhir:short [ fhir:v "L’indicateur permet de signaler que toutes les informations de description d'une offre sont confidentielles car elles présentent un risque d'utilisation à des fins malveillantes. Valeurs possibles :0 = L'offre ne revêt pas de caractère sensible et confidentiel1 = L'offre revêt un caractère sensible et confidentiel" ] ;
       fhir:definition [ fhir:v "L’indicateur permet de signaler que toutes les informations de description d'une offre sont confidentielles car elles présentent un risque d'utilisation à des fins malveillantes. Valeurs possibles :0 = L'offre ne revêt pas de caractère sensible et confidentiel1 = L'offre revêt un caractère sensible et confidentiel" ] ;
