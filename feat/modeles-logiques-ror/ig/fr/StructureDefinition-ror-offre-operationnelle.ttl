     ] [
       fhir:id [ fhir:v "ror-offre-operationnelle.zoneIntervention" ] ;
       fhir:path [ fhir:v "ror-offre-operationnelle.zoneIntervention" ] ;
       fhir:short [ fhir:v "Correspond au périmètre géographique dans lequel habitent les personnes pouvant être prises en charge pour l'offre décrite. Cela inclus notamment les divisions territoriales dans lesquelles les professionnels se déplacent." ] ;
       fhir:definition [ fhir:v "Correspond au périmètre géographique dans lequel habitent les personnes pouvant être prises en charge pour l'offre décrite. Cela inclus notamment les divisions territoriales dans lesquelles les professionnels se déplacent." ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "*" ] ;
