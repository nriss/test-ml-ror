       fhir:id [ fhir:v "ror-entite-geographique.champActivite" ] ;
       fhir:path [ fhir:v "ror-entite-geographique.champActivite" ] ;
       fhir:short [ fhir:v "Champ(s) de l’activité des établissements de santé publics et privés français, notamment : - médecine, chirurgie, obstétrique (MCO),- soins de suite et de réadaptation (SSR), - psychiatrie (PSY).Ces champs d'activité seront enrichis avec l'intégration des établissements du secteur médico-social." ] ;
       fhir:definition [ fhir:v "Champ(s) de l’activité des établissements de santé publics et privés français, notamment : - médecine, chirurgie, obstétrique (MCO),- soins de suite et de réadaptation (SSR), - psychiatrie (PSY).Ces champs d'activité seront enrichis avec l'intégration des établissements du secteur médico-social." ] ;
