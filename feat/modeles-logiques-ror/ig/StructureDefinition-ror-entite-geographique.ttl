       fhir:path [ fhir:v "ror-entite-geographique.niveauRecoursORSAN" ] ;
       fhir:short [ fhir:v "Le niveau de recours ORSAN correspond à une hiérarchisation fonctionnelle de la mobilisation des établissements pour accueillir les patients après régulation par le SAMU." ] ;
       fhir:definition [ fhir:v "Le niveau de recours ORSAN correspond à une hiérarchisation fonctionnelle de la mobilisation des établissements pour accueillir les patients après régulation par le SAMU." ] ;
