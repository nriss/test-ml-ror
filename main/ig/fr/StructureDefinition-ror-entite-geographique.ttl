     ], [
       fhir:index -1 ;
       fhir:Element.id [ fhir:value "ror-entite-geographique.nomOperationnel" ] ;
       fhir:ElementDefinition.path [ fhir:value "ror-entite-geographique.nomOperationnel" ] ;
       fhir:ElementDefinition.short [ fhir:value "Le nom opérationnel est l’appellation communément utilisée par les acteurs de santé pour désigner l'entité géographique, indépendamment des référentiels nationaux." ] ;
       fhir:ElementDefinition.definition [ fhir:value "Le nom opérationnel est l’appellation communément utilisée par les acteurs de santé pour désigner l'entité géographique, indépendamment des référentiels nationaux." ] ;
       fhir:ElementDefinition.min [ fhir:value "0"^^xsd:nonNegativeInteger ] ;
