       fhir:ElementDefinition.path [ fhir:value "ror-entite-geographique.etablissementPrincipal" ] ;
       fhir:ElementDefinition.short [ fhir:value "Dans le cas d’un établissement secondaire : Numéro FINESS de l’établissement principal dont dépend l’établissement." ] ;
       fhir:ElementDefinition.definition [ fhir:value "Dans le cas d’un établissement secondaire : Numéro FINESS de l’établissement principal dont dépend l’établissement." ] ;
