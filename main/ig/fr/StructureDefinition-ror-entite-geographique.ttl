       fhir:ElementDefinition.path [ fhir:value "ror-entite-geographique.complementDenominationEG" ] ;
       fhir:ElementDefinition.short [ fhir:value "Suite de la dénomination de l'entité géographique, si elle existe. Ce complément peut contenir notamment des informations facilitant l'adressage d'un courrier aux structures." ] ;
       fhir:ElementDefinition.definition [ fhir:value "Suite de la dénomination de l'entité géographique, si elle existe. Ce complément peut contenir notamment des informations facilitant l'adressage d'un courrier aux structures." ] ;
