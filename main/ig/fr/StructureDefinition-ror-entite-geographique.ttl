         fhir:ElementDefinition.type.code [ fhir:value "Coding" ]
       ] ;
       fhir:ElementDefinition.binding [
         fhir:ElementDefinition.binding.strength [ fhir:value "preferred" ] ;
         fhir:ElementDefinition.binding.valueSet [
           fhir:value "https://mos.esante.gouv.fr/NOS/TRE_R63-AgregatCategorieEtablissementNiv1/FHIR/TRE-R63-AgregatCategorieEtablissementNiv1?vs" ;
           fhir:link <https://mos.esante.gouv.fr/NOS/TRE_R63-AgregatCategorieEtablissementNiv1/FHIR/TRE-R63-AgregatCategorieEtablissementNiv1?vs>
         ]
       ]
     ], [
       fhir:index -1 ;
       fhir:Element.id [ fhir:value "ror-entite-geographique.agregatCategorieEtablissementNiv2" ] ;
