     ], [
       fhir:index -1 ;
       fhir:Element.id [ fhir:value "ror-entite-geographique.denominationEG" ] ;
       fhir:ElementDefinition.path [ fhir:value "ror-entite-geographique.denominationEG" ] ;
       fhir:ElementDefinition.short [ fhir:value "Dénomination de l'entité géographique (obligatoire dans le ROR)" ] ;
       fhir:ElementDefinition.definition [ fhir:value "Nom sous lequel l'entité géographique exerce son activité. Il s’agit, par exemple, de l’enseigne commerciale pour les pharmacies. Dans le cas d'un établissement enregistré dans le FINESS, cet attribut correspond à la notion de \"raison sociale d'un établissement\" renseignée dans le FINESS." ] ;
