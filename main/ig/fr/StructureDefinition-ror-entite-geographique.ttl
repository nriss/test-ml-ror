       ]
     ], [
       fhir:index -1 ;
       fhir:Element.id [ fhir:value "ror-entite-geographique.champActivite" ] ;
       fhir:ElementDefinition.path [ fhir:value "ror-entite-geographique.champActivite" ] ;
       fhir:ElementDefinition.short [ fhir:value "Champ(s) de l’activité des établissements de santé publics et privés français, notamment : - médecine, chirurgie, obstétrique (MCO),- soins de suite et de réadaptation (SSR), - psychiatrie (PSY).Ces champs d'activité seront enrichis avec l'intégration des établissements du secteur médico-social." ] ;
       fhir:ElementDefinition.definition [ fhir:value "Champ(s) de l’activité des établissements de santé publics et privés français, notamment : - médecine, chirurgie, obstétrique (MCO),- soins de suite et de réadaptation (SSR), - psychiatrie (PSY).Ces champs d'activité seront enrichis avec l'intégration des établissements du secteur médico-social." ] ;
