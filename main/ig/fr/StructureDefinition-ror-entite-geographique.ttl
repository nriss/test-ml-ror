       fhir:ElementDefinition.path [ fhir:value "ror-entite-geographique.numeroEducationNationale" ] ;
       fhir:ElementDefinition.short [ fhir:value "Le \"numéro éducation nationale de l'établissement\" est un numéro associé délivré par l’Éducation nationale, pour tous les établissements et services pour enfants et adolescents handicapés qui emploient du personnel de l’Education nationale." ] ;
       fhir:ElementDefinition.definition [ fhir:value "Le \"numéro éducation nationale de l'établissement\" est un numéro associé délivré par l’Éducation nationale, pour tous les établissements et services pour enfants et adolescents handicapés qui emploient du personnel de l’Education nationale." ] ;
