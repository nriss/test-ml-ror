     ], [
       fhir:index -1 ;
       fhir:Element.id [ fhir:value "ror-entite-geographique.secteurActivite" ] ;
       fhir:ElementDefinition.path [ fhir:value "ror-entite-geographique.secteurActivite" ] ;
       fhir:ElementDefinition.short [ fhir:value "Un secteur d'activité regroupe les établissements partageant la même activité de santé. Exemples (établissement public de santé, maison de santé, etc.)" ] ;
       fhir:ElementDefinition.definition [ fhir:value "Un secteur d'activité regroupe les établissements partageant la même activité de santé. Exemples (établissement public de santé, maison de santé, etc.)" ] ;
       fhir:ElementDefinition.min [ fhir:value "0"^^xsd:nonNegativeInteger ] ;
       fhir:ElementDefinition.max [ fhir:value "1" ] ;
       fhir:ElementDefinition.base [
