       fhir:ElementDefinition.short [ fhir:value "Le type d’établissement détermine si c'est un établissement principal ou secondaire." ] ;
       fhir:ElementDefinition.definition [ fhir:value "Le type d’établissement détermine si c'est un établissement principal ou secondaire." ] ;
