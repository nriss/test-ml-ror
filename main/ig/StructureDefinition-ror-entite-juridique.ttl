       fhir:id [ fhir:v "ror-entite-juridique.agregatStatutJuridiqueNiv2" ] ;
       fhir:path [ fhir:v "ror-entite-juridique.agregatStatutJuridiqueNiv2" ] ;
       fhir:short [ fhir:v "Sous-ensemble d'agrégat de statut juridique (sousEnsembleAgregatStatutJuridique)" ] ;
       fhir:definition [ fhir:v "Agrégat de statut juridique de niveau 2. L'agrégat de niveau 2 représente des regroupements d'agrégats de niveau 3. Par exemple, le code 1100 \"Etat et Collectivités territoriales\" regroupe les codes d'agrégats de niveau 3 1110 et 1120. Il caractérise le statut juridique d’une structure au sens du droit applicable (public / privé) et de la finalité (non lucratif / commercial)." ] ;
