         ]
       ]
     ] [
       fhir:id [ fhir:v "ror-entite-juridique.agregatStatutJuridiqueNiv1" ] ;
       fhir:path [ fhir:v "ror-entite-juridique.agregatStatutJuridiqueNiv1" ] ;
       fhir:short [ fhir:v "Agrégat de statut juridique de niveau 1. L'agrégat de niveau 1 représente des regroupements d'agrégats de niveau 2. Par exemple, le code 1000 \"Organismes et Etablissements publics\" regroupe les codes d'agrégat de niveau 2 1100 et 1200." ] ;
