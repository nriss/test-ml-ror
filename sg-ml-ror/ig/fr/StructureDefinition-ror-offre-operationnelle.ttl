     ], [
       fhir:index -1 ;
       fhir:Element.id [ fhir:value "ror-offre-operationnelle.uniteSensible" ] ;
       fhir:ElementDefinition.path [ fhir:value "ror-offre-operationnelle.uniteSensible" ] ;
       fhir:ElementDefinition.short [ fhir:value "Indicateur de confidentialité de l'offre (obligatoire dans le ROR)" ] ;
       fhir:ElementDefinition.definition [ fhir:value "L’indicateur permet de signaler que toutes les informations de description d'une offre sont confidentielles car elles présentent un risque d'utilisation à des fins malveillantes. Valeurs possibles :0 = L'offre ne revêt pas de caractère sensible et confidentiel1 = L'offre revêt un caractère sensible et confidentiel" ] ;
       fhir:ElementDefinition.min [ fhir:value "1"^^xsd:nonNegativeInteger ] ;
       fhir:ElementDefinition.max [ fhir:value "1" ] ;
       fhir:ElementDefinition.base [
