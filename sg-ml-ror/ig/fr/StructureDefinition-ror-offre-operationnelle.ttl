       fhir:ElementDefinition.path [ fhir:value "ror-offre-operationnelle.specialisationPriseEnCharge" ] ;
       fhir:ElementDefinition.short [ fhir:value "Une spécialisation de prise en charge correspond à un regroupement de troubles, de pathologies ou de déficiences qui nécessitent la mobilisation d'expertises, de compétences et/ou d'équipements spécifiques pouvant être discriminants dans le choix d’orientation du patient." ] ;
       fhir:ElementDefinition.definition [ fhir:value "Une spécialisation de prise en charge correspond à un regroupement de troubles, de pathologies ou de déficiences qui nécessitent la mobilisation d'expertises, de compétences et/ou d'équipements spécifiques pouvant être discriminants dans le choix d’orientation du patient." ] ;
