       fhir:Extension.url [ fhir:value "requirement" ] ;
       fhir:Extension.valueMarkdown [ fhir:value "**RG_EXP_041** : Si l'attribut `fonctionContact` est renseigné dans l'objet Contact, alors il doit y avoir un `nom` de contact et il ne doit pas y avoir de `natureContact`." ]
     ], [
