<https://interop.esante.gouv.fr/ig/fhir/test-ror/Basic/ror-requirements-structure> a fhir:Basic ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:Resource.id [ fhir:value "ror-requirements-structure"] ;
  fhir:Resource.meta [
     fhir:Meta.profile [
       fhir:value "http://hl7.org/fhir/5.0/StructureDefinition/profile-Requirements" ;
       fhir:index -1 ;
       fhir:link <http://hl7.org/fhir/5.0/StructureDefinition/profile-Requirements>
